generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [uuidOssp(map: "uuid-ossp")]
}

model User {
  id       String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name     String
  email    String   @unique
  password String
  cep      String
  admin    Boolean  @default(false)

  cartItems CartItem[]
}

model Product {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  description String
  price       Int
  category    String 
  img         String
  createdAt   DateTime   @default(now())

  cartItems   CartItem[]
}

model CartItem { 
  id        String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id]) 

  userId    String  @db.Uuid
  user      User    @relation(fields: [userId], references: [id])
}


// Como fazer a relação entre o User e o Product?
// A relação entre User e Product é feita através do modelo CartItem, que atua como umatabela de junção (join table) entre os dois modelos. Cada CartItem representa um item no carrinho de um usuário, associando um produto específico a um usuário específico.
// No modelo CartItem, temos os campos productId e userId, que são chaves estrangeiras referenciando os modelos Product e User, respectivamente. Através dessas chaves estrangeiras, podemos estabelecer a relação entre os usuários e os produtos que eles adicionaram ao carrinho.
// Comando para ver a tabela no banco de dados:
//SELECT "CartItem".*, "Product".* FROM "CartItem" INNER JOIN "Product" ON "CartItem"."productId" = "Product"."id"

